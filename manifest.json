{
  "version": 0,
  "require": {
    "cockpit": "300"
  },
  "tools": {
    "index": {
      "label": "Keylime Webtool",
      "keywords": [
        {
          "matches": ["keylime", "attestation", "tpm", "remote attestation", "integrity"]
        }
      ]
    }
  },
  "conditions": [
    { "path-exists": "/etc/keylime" }
  ],
  "content-security-policy": "default-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
}
